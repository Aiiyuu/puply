{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.fixAll.golangci-lint": "explicit"
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  // Tells ESLint where to look in your monorepo
  "eslint.workingDirectories": [
    { "pattern": "apps/*/", "changeProcessCWD": true },
    { "pattern": "packages/*/", "changeProcessCWD": true }
  ],
  "editor.importOrder": "none",

  // TypeScript & React
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // JSON - Explicitly force Prettier here
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // CSS
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Go (Backend)
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll.golangci-lint": "explicit"
    }
  },

  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "go.alternateTools": {
    "golangci-lint": "/Users/nazariyholovach/go/bin/golangci-lint"
  },
  "golangci-lint.runOptions": ["--config=apps/api/.golangci.yml", "--fix"],

  "makefile.configureOnOpen": false
}
